{
  "name": "genxapi-action",
  "version": "0.1.0",
  "description": "Official GitHub Action wrapper for running the GenX API CLI in GitHub workflows.",
  "license": "Apache-2.0",
  "private": false,
  "main": "dist/index.js",
  "scripts": {
    "bundle": "esbuild src/index.js --bundle --platform=node --format=cjs --target=node20 --outfile=dist/index.js --legal-comments=external",
    "check": "node --check src/index.js"
  },
  "keywords": [
    "github-action",
    "genxapi",
    "openapi",
    "codegen"
  ],
  "files": [
    "action.yml",
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@actions/core": "1.11.1"
  },
  "devDependencies": {
    "esbuild": "0.25.1"
  }
}
